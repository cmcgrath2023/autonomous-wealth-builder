# Copy to /opt/awb/.env.runtime on the droplet and fill in the secrets.

# Alpaca (US equities)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_MODE=paper

# Trident intelligence platform
BRAIN_API_KEY=
BRAIN_SERVER_URL=https://trident.cetaceanlabs.com

# Discord
DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=

# PostgreSQL (research-db — thesis pipeline, knowledge graph)
DATABASE_URL=postgresql://awb:changeme@localhost:5432/awb_research

# OANDA (forex — optional)
OANDA_API_KEY=
OANDA_ACCOUNT_ID=

# Optional overrides
AWB_GATEWAY_LOCK_PATH=/app/services/data/awb-gateway.lock
GATEWAY_DB_PATH=/app/services/data/gateway-state.db
AWB_SERVICES_TAG=latest
AWB_UI_TAG=latest
